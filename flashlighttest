#!/usr/bin/env node

/**
 * flashlighttest — Run Flashlight tests on your farm server and pull the report locally.
 * Works entirely over port 3000 (HTTP + WebSocket). No SSH required.
 *
 * Usage:
 *   flashlighttest sample-test-fl.js
 *   flashlighttest sample-test-fl.js --no-open
 *
 * One-time config (~/.flashlighttest.json):
 *   {
 *     "host":       "13.239.102.204",
 *     "port":       "3000",
 *     "reportsDir": "./flashlight-reports"
 *   }
 */

const { execSync }  = require('child_process');
const fs            = require('fs');
const path          = require('path');
const os            = require('os');
const WebSocket     = require('ws');

// ─── Colours ──────────────────────────────────────────────────────────────────
const c = {
  reset: '\x1b[0m', bold: '\x1b[1m',
  cyan: '\x1b[36m', green: '\x1b[32m', yellow: '\x1b[33m', red: '\x1b[31m', dim: '\x1b[2m',
};
const log  = (icon, msg) => console.log(`${c.cyan}${icon}${c.reset}  ${msg}`);
const ok   = (msg)       => console.log(`${c.green}✓${c.reset}  ${msg}`);
const warn = (msg)       => console.log(`${c.yellow}⚠${c.reset}  ${msg}`);
const fail = (msg)       => { console.error(`${c.red}✗${c.reset}  ${msg}`); process.exit(1); };

// ─── Config ───────────────────────────────────────────────────────────────────
function loadConfig() {
  const cfgPath = path.join(os.homedir(), '.flashlighttest.json');
  let file = {};
  if (fs.existsSync(cfgPath)) {
    try { file = JSON.parse(fs.readFileSync(cfgPath, 'utf8')); }
    catch { warn(`Could not parse ${cfgPath} — ignoring`); }
  }
  return {
    host:       process.env.EC2_HOST    || file.host,
    port:       process.env.EC2_PORT    || file.port       || '3000',
    reportsDir: process.env.REPORTS_DIR || file.reportsDir || './flashlight-reports',
  };
}

// ─── Args ─────────────────────────────────────────────────────────────────────
function parseArgs() {
  const args = process.argv.slice(2);
  if (!args.length || args[0] === '--help' || args[0] === '-h') {
    console.log(`
${c.bold}flashlighttest${c.reset} — run Flashlight tests on EC2, stream logs live, download report

${c.bold}Usage:${c.reset}
  flashlighttest <test-file.js> [--no-open]

${c.bold}Config (~/.flashlighttest.json):${c.reset}
  {
    "host":       "13.239.102.204",
    "port":       "3000",
    "reportsDir": "./flashlight-reports"
  }
`);
    process.exit(0);
  }
  const testFile = args[0];
  const autoOpen = !args.includes('--no-open');
  return { testFile, autoOpen };
}

// ─── HTTP helpers ─────────────────────────────────────────────────────────────
function baseUrl(cfg) { return `http://${cfg.host}:${cfg.port}`; }

async function httpPost(cfg, endpoint, body) {
  const res = await fetch(`${baseUrl(cfg)}${endpoint}`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body),
  });
  const json = await res.json();
  if (!res.ok) throw new Error(json.error || `HTTP ${res.status}`);
  return json;
}

async function httpGet(cfg, endpoint) {
  const res = await fetch(`${baseUrl(cfg)}${endpoint}`);
  const json = await res.json();
  if (!res.ok) throw new Error(json.error || `HTTP ${res.status}`);
  return json;
}

async function httpDelete(cfg, endpoint) {
  const res = await fetch(`${baseUrl(cfg)}${endpoint}`, { method: 'DELETE' });
  const json = await res.json();
  if (!res.ok) throw new Error(json.error || `HTTP ${res.status}`);
  return json;
}

async function httpDownload(cfg, endpoint, localPath) {
  const res = await fetch(`${baseUrl(cfg)}${endpoint}`);
  if (!res.ok) throw new Error(`HTTP ${res.status}`);
  const buf = await res.arrayBuffer();
  fs.writeFileSync(localPath, Buffer.from(buf));
}

// ─── WebSocket — trigger test + stream logs live ──────────────────────────────
// Protocol:
//   client → server : { run: 'sample-test-fl.js' }
//   server → client : { type: 'log',  line: '...' }   (one per stdout/stderr line)
//   server → client : { type: 'done', exitCode: 0 }   (test finished)
//   server → client : { type: 'error', message: '...' }
function runTestOverWebSocket(cfg, testFile) {
  return new Promise((resolve, reject) => {
    const wsUrl = `ws://${cfg.host}:${cfg.port}/test-runner`;
    let settled = false;

    const settle = (fn, val) => {
      if (settled) return;
      settled = true;
      fn(val);
    };

    let ws;
    try { ws = new WebSocket(wsUrl); }
    catch (e) { return reject(new Error(`Could not connect WebSocket: ${e.message}`)); }

    // 10 second connection timeout
    const connTimeout = setTimeout(() => {
      ws.terminate();
      settle(reject, new Error(`WebSocket timed out connecting to ${wsUrl}`));
    }, 10000);

    ws.on('open', () => {
      clearTimeout(connTimeout);
      ws.send(JSON.stringify({ run: testFile }));
    });

    ws.on('message', raw => {
      let msg;
      try { msg = JSON.parse(raw.toString()); } catch { return; }

      if (msg.type === 'log') {
        process.stdout.write(msg.line + '\n');
      } else if (msg.type === 'done') {
        ws.close(1000);
        if (msg.exitCode === 0) settle(resolve);
        else settle(reject, new Error(`Test exited with code ${msg.exitCode}`));
      } else if (msg.type === 'error') {
        ws.close(1000);
        settle(reject, new Error(msg.message));
      }
    });

    ws.on('error', e => {
      clearTimeout(connTimeout);
      settle(reject, new Error(`WebSocket error: ${e.message}`));
    });

    ws.on('close', (code) => {
      clearTimeout(connTimeout);
      // Abnormal close and we haven't settled yet → treat as error
      if (code !== 1000 && code !== 1005) {
        settle(reject, new Error(`WebSocket closed unexpectedly (code ${code})`));
      }
    });
  });
}

// ─── Main ─────────────────────────────────────────────────────────────────────
async function main() {
  const args   = parseArgs();
  const config = loadConfig();

  if (!config.host) fail('Farm host not set. Add "host" to ~/.flashlighttest.json or set EC2_HOST.');

  const { testFile, autoOpen } = args;
  const reportsDir = path.resolve(config.reportsDir);

  console.log(`\n${c.bold}${c.cyan}⚡ flashlighttest${c.reset}\n`);
  log('🖥 ', `Farm:      ${config.host}:${config.port}`);
  log('🧪', `Test:      ${testFile}`);
  console.log();

  // ── 1. Upload test file via HTTP ──────────────────────────────────────────
  log('📤', `Uploading ${testFile}...`);
  const localTestPath = path.resolve(testFile);
  if (!fs.existsSync(localTestPath)) fail(`File not found: ${localTestPath}`);
  try {
    const content = fs.readFileSync(localTestPath, 'utf8');
    await httpPost(config, '/api/deploy', { filename: testFile, content });
    ok(`Uploaded ${testFile}`);
  } catch (e) {
    fail(`Upload failed: ${e.message}`);
  }

  // ── 2. Run via WebSocket — live log stream ────────────────────────────────
  log('🚀', 'Running test (live output):\n');
  try {
    await runTestOverWebSocket(config, testFile);
    console.log();
    ok('Test completed');
  } catch (e) {
    console.log();
    fail(e.message);
  }

  // ── 3. List reports on server ─────────────────────────────────────────────
  log('🔍', 'Locating reports...');
  let reports;
  try {
    const res = await httpGet(config, '/api/reports');
    reports = res.reports;
    if (!reports.length) fail('No reports found — did writeResults() run?');
    log('📋', `Found ${reports.length} report(s)`);
  } catch (e) {
    fail(`Could not list reports: ${e.message}`);
  }

  // ── 4. Download all reports ───────────────────────────────────────────────
  log('⬇️ ', 'Downloading...');
  fs.mkdirSync(reportsDir, { recursive: true });
  const downloaded = [];
  for (const filename of reports) {
    const localFile = path.join(reportsDir, filename);
    try {
      await httpDownload(config, `/api/reports/${encodeURIComponent(filename)}`, localFile);
      downloaded.push(localFile);
      ok(`Saved: ${filename}`);
    } catch (e) {
      warn(`Failed: ${filename} — ${e.message}`);
    }
  }
  if (!downloaded.length) fail('No reports could be downloaded.');

  // ── 5. Delete reports from server ─────────────────────────────────────────
  log('🧹', 'Cleaning up server...');
  try {
    await httpDelete(config, '/api/reports');
    ok('Done');
  } catch (e) {
    warn(`Cleanup failed: ${e.message}`);
  }

  // ── 6. Open latest report locally ─────────────────────────────────────────
  const latest = downloaded[0];
  console.log(`\n${c.bold}${c.green}✅ Done!${c.reset}  ${downloaded.length} report(s) → ${reportsDir}`);
  downloaded.forEach(f => console.log(`  ${c.dim}•${c.reset} ${path.basename(f)}`));
  console.log();

  if (autoOpen) {
    log('🌐', 'Opening report...');
    try {
      execSync(`npx flashlight report "${latest}"`, { stdio: 'inherit' });
    } catch {
      warn(`Could not open. Run:\n   npx flashlight report "${latest}"`);
    }
  } else {
    console.log(`To view:\n  npx flashlight report "${latest}"\n`);
  }
}

main().catch(e => fail(e.message));
